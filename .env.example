PORT=4200
PASS=1234
IMG_FOLDER=C:\sd-webui\outputs
# optional, ComfyUI URL used by "Open in ComfyUI" (defaults to http://127.0.0.1:8188)
#COMFY_URL=http://127.0.0.1:8188
# optional, ComfyUI-Login API token from the Comfy console
#COMFY_TOKEN=
# optional, defaults to ./localData (npm run dev uses ./devLocalData and ./devImages)
#LOCAL_DATA=./localData
# optional, positive values will enable polling, 0 will disable it
#POLLING_SECONDS=5